<% layout("/layouts/boilerplate") -%>
<div class="row">
  <div class="col-8 offset-2 mt-3">
    <h3><%= listing.title %></h3>
  </div>
  <div class="card listing-card col-8 offset-2 mt-2">
    <img
      src="<%= listing.image %>"
      class="card-img-top show-img"
      alt="listing image"
    />
    <p class="card-text">
      <%= listing.description %> <br />
      &#8377; <%= listing.price.toLocaleString("en-IN") %> <br />
      <%= listing.location %> <br />
      <%= listing.country %>
    </p>

    <div class="btns row">
      <div class="col-2">
        <a href="/listings/<%= listing._id %>/edit" class="btn btn-dark new-btn"
          >Edit</a
        >
      </div>
      <div class="col-1">
        <form
          method="post"
          action="/listings/<%= listing._id %>?_method=DELETE"
        >
          <button class="btn btn-dark">Delete</button>
        </form>
      </div>
    </div>

    <hr />

    <div class="mt-3 ">
      <h4>Leave a Review</h4>
      <form
        action="/listings/<%= listing.id %>/reviews"
        method="post"
        novalidate
        class="needs-validation"
      >
        <div>
          <label for="rating">Rating </label>
          <input
            type="range"
            id="rating"
            name="review[rating]"
            class="form-range"
            min="1"
            max="5"
          />
        </div>
        <div class="mb-2">
          <label for="comment" class="form-label">Comment </label>
          <textarea
            name="review[comment]"
            id="comment"
            cols="30"
            row="5"
            class="form-control"
            required
          ></textarea>
          <div class="valid-feedback">Looks good!</div>
          <div class="invalid-feedback">
            Please submit Some comment for review.
          </div>
        </div>
        <Button class="btn btn-outline-dark">Submit</Button>
      </form>
    </div>

    <hr />

    <p><b>All Review</b></p>
    <div class="row">
      <% for( let review of listing.reviews ) { %>
      <div class="card col-5 mb-3 ms-2">
        <h5 class="card-title">Jhon Deo</h5>
        <p class="card-text"><%= review.comment %></p>
        <p class="card-text"><%= review.rating %> Stars</p>
        <form method="POST" action="/listings/<%= listing._id %>/reviews/<%= review._id %>?_method=DELETE" class="mb-3">
          <button class="btn btn-sm btn-dark">Delete</button>
        </form>
      </div>
      <% } %>
    </div>
  </div>
</div>
